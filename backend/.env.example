# Frontend origin for CORS
FRONTEND_ORIGIN=http://localhost:3000

# Session cookie secret
SESSION_SECRET=change-me-in-production

# Environment (set to "production" in Railway)
ENV=development

# F1 Fantasy credentials (optional; if set, blank login form fields fall back
# to these so you can sign in locally without re-typing them).
F1_EMAIL=your-email@example.com
F1_PASSWORD=your-password
F1_LEAGUE_ID=10328108
